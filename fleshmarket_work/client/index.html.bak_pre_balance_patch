<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
<title>Flesh Market — Local</title>
<link rel="stylesheet" href="style.css"/>
</head>
<body>
<div class="wrap">
  <div class="row" style="justify-content:space-between;align-items:center;margin-bottom:8px">
    <div>
      <h1 style="margin:0;font-size:18px;letter-spacing:.14em">FLESH MARKET</h1>
      <small class="muted"></small>
    </div>
    <div class="row">
      <input id="name" class="input" placeholder="Your name"/>
      <button id="helloBtn" class="btn">Join</button>
    </div>
  </div>

  <div class="grid">
    <!-- Left: tickers + news -->
    <div class="panel">
      <h2>Companies</h2>
      <input id="search" class="input" placeholder="Search symbol or name"/>
      <div id="tickers" class="list"></div>
      <hr/>
      <h2>News</h2>
      <div id="news" class="news"></div>
    </div>

    <!-- Center: chart + trade + tabs -->
    <div class="panel">
      <div class="tabs">
        <div class="tab active" data-tab="market">Market</div>
        <div class="tab" data-tab="pnl">P&amp;L</div>
        <div class="tab" data-tab="casino">Casino</div>
      </div>

      <div id="marketTab">
        <canvas id="chart"></canvas>
        <div class="row" style="margin-top:8px">
          <input id="sym" class="input" placeholder="Symbol (e.g. ORGX)" style="max-width:140px"/>
          <input id="shares" class="input" type="number" min="1" value="1" style="max-width:120px"/>
          <button id="buy" class="btn">Buy</button>
          <button id="sell" class="btn">Sell</button>
          <div id="cash" class="muted" style="margin-left:auto"></div>
        </div>
        <div id="positions" class="list" style="margin-top:8px"></div>
      </div>

      <div id="pnlTab" style="display:none">
        <div id="pnlBox" class="list"></div>
        <canvas id="equity" style="width:100%;height:160px;margin-top:8px"></canvas>
      </div>

        <div id="casinoTab" style="display:none">
          <div class="tabs" id="casinoTabs">
            <div class="subtab active" data-subtab="roulette">Roulette</div>
            <div class="subtab" data-subtab="blackjack">Blackjack</div>
            <div class="subtab" data-subtab="poker">Poker</div>
            <div class="subtab" data-subtab="horseraces">Horse Races</div>
            <div class="subtab" data-subtab="chess">Chess</div>
          </div>
          <div id="casinoContent" style="margin-top:8px">
            <div id="casino-roulette" class="casino-pane" style="display:block"></div>
            <div id="casino-blackjack" class="casino-pane" style="display:none"></div>
            <div id="casino-poker" class="casino-pane" style="display:none"></div>
            <div id="casino-horseraces" class="casino-pane" style="display:none"></div>
            <div id="casino-chess" class="casino-pane" style="display:none"></div>
          </div>
        </div>

    </div>

    <!-- Right: chat + leaderboard + transfers -->
    <div class="panel">
      <h2>Chatroom</h2>
      <div id="chat" class="chatlog"></div>
      <div class="row" style="margin-top:6px">
        <input id="chatInput" class="input" placeholder="Say something"/>
        <button id="chatSend" class="btn">Send</button>
      </div>
      <hr/>
      <h2>Leaderboard</h2>
      <div id="board" class="list"></div>
      <hr/>
      <h2>Transfer (2% tax)</h2>
      <div class="row">
        <input id="toName" class="input" placeholder="Recipient name"/>
        <input id="amt" class="input" type="number" min="1" value="10" style="max-width:110px"/>
        <button id="xfer" class="btn">Send</button>
      </div>
    </div>
  </div>
</div>

<script>
const ws = new WebSocket((location.protocol === 'https:' ? 'wss://' : 'ws://') + location.host);
const el = sel => document.querySelector(sel);
const list = sel => document.querySelector(sel);

let ME = null;
let TICKERS = [];
let CURRENT = null;
let OHLC = [];

function fmt(n){ return '¤' + (Math.round(n*100)/100).toLocaleString(); }

function renderTickers() {
  const q = el('#search').value.toLowerCase();
  const box = el('#tickers');
  box.innerHTML = '';
  TICKERS.filter(t => !q || t.symbol.toLowerCase().includes(q) || t.name.toLowerCase().includes(q))
    .forEach(t => {
      const row = document.createElement('div');
      row.className = 'ticker';
      row.innerHTML = `<div><span class="sym">${t.symbol}</span> — <span class="muted">${t.name.replace(/\d+$/, '')}</span></div>
                       <div class="px">${fmt(t.price)}</div>`;
      row.style.cursor = 'pointer';
      row.onclick = () => { el('#sym').value = t.symbol; CURRENT = t.symbol; ws.send(JSON.stringify({type:'chart', symbol:t.symbol})); };
      box.appendChild(row);
    });
}

function renderNews(item) {
  const box = el('#news');
  const div = document.createElement('div');
  const tone = item.tone === 'good' ? 'green' : (item.tone === 'bad' ? 'red' : '');
  div.innerHTML = `<div class="${tone}">${new Date(item.t).toLocaleTimeString()} — ${item.text}</div>`;
  box.prepend(div);
  while (box.children.length > 100) box.removeChild(box.lastChild);
}

function renderBoard(data) {
  const box = el('#board');
  box.innerHTML = '';
  data.forEach((p,i)=>{
    const row = document.createElement('div');
    row.innerHTML = `${i+1}. <b>${p.name}</b> — ${fmt(p.net)} <span class="muted">Lv.${p.level} XP:${p.xp}</span>`;
    box.appendChild(row);
  });
}

function renderPositions(p) {
  el('#cash').textContent = fmt(p.cash);
  const box = el('#positions');
  box.innerHTML = '';
  p.positions.forEach(po => {
    const row = document.createElement('div');
    row.innerHTML = `${po.sym} — ${po.qty} @ ${fmt(po.px)} = ${fmt(po.val)}`;
    box.appendChild(row);
  });
  try { EQUITY.push({t: Date.now(), net: p.net, equity: p.equity, cash: p.cash}); while(EQUITY.length>500) EQUITY.shift(); } catch(e) {}
  renderPnLDetail(p);
  drawEquity();
}


// === P&L & Equity Line Enhancements (minimal, drop‑in) ===
let EQUITY = []; // [{t, net, equity, cash}]
function drawEquity() {
  const canvas = el('#equity');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width = canvas.clientWidth;
  const H = canvas.height = canvas.clientHeight;
  ctx.fillStyle = '#0a0804';
  ctx.fillRect(0,0,W,H);
  if (!EQUITY.length) return;

  const xs = EQUITY.map(d=>d.t);
  const ys = EQUITY.map(d=>d.net);
  const minY = Math.min(...ys);
  const maxY = Math.max(...ys);
  const padY = (maxY-minY)*0.1 || 1;
  const lo = minY - padY, hi = maxY + padY;
  const minX = xs[0], maxX = xs[xs.length-1];

  // gridlines
  ctx.strokeStyle = '#232018';
  ctx.lineWidth = 1;
  ctx.beginPath();
  for (let i=1;i<=4;i++) {
    const y = H * (i/5);
    ctx.moveTo(0,y); ctx.lineTo(W,y);
  }
  ctx.stroke();

  // line
  ctx.strokeStyle = '#98ff9f';
  ctx.lineWidth = 2;
  ctx.beginPath();
  for (let i=0;i<xs.length;i++) {
    const x = ( (xs[i]-minX) / (maxX-minX || 1) ) * W;
    const y = H - ((ys[i]-lo) / (hi-lo || 1)) * H;
    if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
  }
  ctx.stroke();
}

function renderPnLDetail(p) {
  // Compute Unrealized by symbol and totals
  const rows = [];
  let unrealTot = 0;
  (p.positions||[]).forEach(po=>{
    const cost = po.px * po.qty;
    const unrl = (po.val - cost);
    unrealTot += unrl;
    rows.push(`${po.sym}: ${fmt(unrl)} <span class="muted">(qty ${po.qty} @ ${fmt(po.px)})</span>`);
  });

  const last = EQUITY.length ? EQUITY[EQUITY.length-1] : null;
  const prev = EQUITY.length>1 ? EQUITY[EQUITY.length-2] : null;
  const deltaNet = last && prev ? (last.net - prev.net) : 0;

  const box = el('#pnlBox');
  const parts = [
    `Net Worth: <b>${fmt(p.net)}</b>`,
    `Equity: ${fmt(p.equity)}`,
    `Cash: ${fmt(p.cash)}`,
    `Unrealized P&L: <b>${fmt(unrealTot)}</b>`,
    `Δ Since Last Tick: ${fmt(deltaNet)}`,
  ];
  box.innerHTML = parts.join(' — ') + '<hr/>' + rows.map(r=>`<div>${r}</div>`).join('');
}

function drawChart() {
  const canvas = el('#chart');
  const ctx = canvas.getContext('2d');
  const W = canvas.width = canvas.clientWidth;
  const H = canvas.height = canvas.clientHeight;
  ctx.fillStyle = '#0a0804';
  ctx.fillRect(0,0,W,H);

  if (!OHLC.length) return;
  const min = Math.min(...OHLC.map(d=>d.l));
  const max = Math.max(...OHLC.map(d=>d.h));
  const pad = (max-min)*0.1 || 1;
  const low = min - pad, high = max + pad;

  const n = OHLC.length;
  const cw = W / n;

  // grid
  ctx.strokeStyle = '#2b200a';
  ctx.lineWidth = 1;
  for (let i=0;i<6;i++){
    const y = i * (H/5);
    ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke();
  }

  // candles
  for (let i=0;i<n;i++){
    const d = OHLC[i];
    const x = i * cw + cw*0.5;
    const yH = H - ( (d.h - low) / (high - low) ) * H;
    const yL = H - ( (d.l - low) / (high - low) ) * H;
    const yO = H - ( (d.o - low) / (high - low) ) * H;
    const yC = H - ( (d.c - low) / (high - low) ) * H;
    // wick
    ctx.strokeStyle = '#d4a05e';
    ctx.beginPath(); ctx.moveTo(x, yH); ctx.lineTo(x, yL); ctx.stroke();
    // body
    const up = d.c >= d.o;
    ctx.fillStyle = up ? '#86ff6a' : '#ff6b6b';
    const top = Math.min(yO, yC);
    const h = Math.max(2, Math.abs(yC - yO));
    ctx.fillRect(x - cw*0.35, top, cw*0.7, h);
  }

  // symbol label
  ctx.fillStyle = '#ffd089';
  ctx.fillText(CURRENT || '—', 8, 14);
}

function addChat(item){
  const box = el('#chat');
  const div = document.createElement('div');
  div.innerHTML = `<b>${item.user}</b>: ${item.text}`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

// Tabs
document.querySelectorAll('.tab').forEach(tab=>{
  tab.addEventListener('click', ()=>{
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    const sel = tab.dataset.tab;
    el('#marketTab').style.display = sel==='market'?'block':'none';
    el('#pnlTab').style.display = sel==='pnl'?'block':'none';
    el('#casinoTab').style.display = sel==='casino'?'block':'none';
    // ensure the equity line renders when the P&L tab becomes visible
    if (sel==='pnl') { setTimeout(()=>{ try { drawEquity(); } catch(e){} }, 0); }
  });

  // Casino subtabs (placeholders only)
  document.querySelectorAll('#casinoTabs .subtab').forEach(st=>{
    st.addEventListener('click', ()=>{
      document.querySelectorAll('#casinoTabs .subtab').forEach(t=>t.classList.remove('active'));
      st.classList.add('active');
      const which = st.dataset.subtab;
      ['roulette','blackjack','poker','horseraces','chess'].forEach(name=>{
        const pane = el('#casino-'+name);
        if (pane) pane.style.display = (name===which)?'block':'none';
      });
    });
  });

});

// Redraw equity on resize (keeps line tidy on different layouts)
try {
  const ro = new ResizeObserver(()=>{ try { drawEquity(); } catch(e){} });
  const pnl = document.getElementById('pnlTab');
  if (pnl) ro.observe(pnl);
} catch(e) {}
// UI events
el('#helloBtn').onclick = ()=>{
  const name = el('#name').value.trim() || undefined;
  ws.send(JSON.stringify({type:'hello', name}));
  ws.send(JSON.stringify({type:'request_state'}));
};

el('#buy').onclick = ()=>{
  ws.send(JSON.stringify({type:'order', side:'buy', symbol:el('#sym').value, shares:Number(el('#shares').value||1)}));
};
el('#sell').onclick = ()=>{
  ws.send(JSON.stringify({type:'order', side:'sell', symbol:el('#sym').value, shares:Number(el('#shares').value||1)}));
};

el('#xfer').onclick = ()=>{
  ws.send(JSON.stringify({type:'transfer', toName:el('#toName').value, amount:Number(el('#amt').value||0)}));
};

el('#chatSend').onclick = ()=>{
  const t = el('#chatInput').value.trim();
  if (!t) return;
  ws.send(JSON.stringify({type:'chat', text:t}));
  el('#chatInput').value='';
};

el('#search').addEventListener('input', renderTickers);

// WS handlers
ws.addEventListener('open', ()=>{});
ws.addEventListener('message', (ev)=>{
  const msg = JSON.parse(ev.data);
  if (msg.type === 'welcome') {
    ME = msg.data;
  }
  if (msg.type === 'init') {
    TICKERS = msg.data.companies;
    renderTickers();
    msg.data.leaderboard && renderBoard(msg.data.leaderboard);
    msg.data.headlines && msg.data.headlines.slice(-10).forEach(renderNews);
  }
  if (msg.type === 'tick') {
    TICKERS = msg.data;
    renderTickers();
    if (CURRENT) { ws.send(JSON.stringify({type:'chart', symbol: CURRENT})); }
  }
  if (msg.type === 'news') {
    renderNews(msg.data);
  }
  if (msg.type === 'leaderboard') {
    renderBoard(msg.data);
  }
  if (msg.type === 'portfolio') {
    renderPositions(msg.data);
  }
  if (msg.type === 'chart') {
    if (msg.data && msg.data.ohlc) {
      OHLC = msg.data.ohlc;
      drawChart();
    }
  }
  if (msg.type === 'chat') addChat(msg.data);
});

// ===== Casino: Roulette (European, single zero) =====
(function(){
  const pane = document.getElementById('casino-roulette');
  if (!pane) return;

  // European wheel number order (clockwise), starting from 0 at the top
  const ORDER = [0,32,15,19,4,21,2,25,17,34,6,27,13,36,11,30,8,23,10,5,24,16,33,1,20,14,31,9,22,18,29,7,28,12,35,3,26];
  const REDS = new Set([1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36]);

  pane.innerHTML = `
    <div class="row">
      <div id="rouletteWheel" class="crt" style="flex:0 0 320px; padding:12px; border:1px solid var(--dim)">
        <canvas id="wheelCanvas" width="300" height="300"></canvas>
        <div id="lastResult" class="muted" style="margin-top:8px">Last: —</div>
      </div>
      <div style="flex:1; padding-left:12px">
        <div class="row" style="gap:8px; flex-wrap:wrap">
          <input id="betAmount" class="input" type="number" min="1" value="10" style="max-width:120px"/>
          <button id="placeBet" class="btn">Place Bet</button>
          <button id="spinBtn" class="btn">Spin</button>
          <div id="rouletteBalance" class="muted" style="margin-left:auto">Balance: —</div>
        </div>
        <div id="betTypeRow" class="row" style="gap:8px; margin-top:8px; flex-wrap:wrap">
          <select id="betType" class="input" style="max-width:180px">
            <option value="straight">Straight (number 0-36)</option>
            <option value="red">Red</option>
            <option value="black">Black</option>
            <option value="odd">Odd</option>
            <option value="even">Even</option>
            <option value="dozen1">1st 12 (1-12)</option>
            <option value="dozen2">2nd 12 (13-24)</option>
            <option value="dozen3">3rd 12 (25-36)</option>
          </select>
          <input id="straightNum" class="input" type="number" min="0" max="36" value="7" style="max-width:110px; display:inline-block"/>
        </div>
        <div id="betsList" class="list" style="margin-top:8px"></div>
      </div>
    </div>
  `;

  // Shared balance helpers (account-wide)
  function fmtLocal(n){ return '¤' + (Math.round(n*100)/100).toLocaleString(); }
  function getBalance() {
    if (typeof ME === 'object' && ME && typeof ME.cash === 'number') return ME.cash;
    const c = document.getElementById('cash');
    if (c && c.textContent) {
      const n = Number(c.textContent.replace(/[^\d.-]/g,''));
      if (!Number.isNaN(n)) return n;
    }
    const s = localStorage.getItem('casino_balance_shadow');
    return s ? Number(s) : 0;
  }
  function setBalance(newVal) {
    if (typeof ME === 'object' && ME && typeof ME.cash === 'number') { ME.cash = newVal; }
    const c = document.getElementById('cash'); if (c) c.textContent = fmtLocal(newVal);
    localStorage.setItem('casino_balance_shadow', String(newVal));
    try { ws && ws.send && ws.send(JSON.stringify({type:'casino', game:'roulette', delta:0, sync:newVal})); } catch(e){}
    refreshRouletteBalance();
  }
  function adjustBalance(delta){ setBalance(getBalance()+delta); }
  function refreshRouletteBalance(){
    const lbl = document.getElementById('rouletteBalance');
    if (lbl) lbl.textContent = 'Balance: ' + fmtLocal(getBalance());
  }

  // Bet slip
  const bets = [];
  function renderBets(){
    const box = document.getElementById('betsList');
    if (!box) return;
    if (!bets.length){ box.innerHTML = '<div class="muted">No bets placed yet.</div>'; return; }
    box.innerHTML = '';
    bets.forEach(b=>{
      const row = document.createElement('div');
      row.className = 'row';
      row.style.justifyContent = 'space-between';
      row.innerHTML = `<div>${b.label}</div><div>${fmtLocal(b.amount)}</div>`;
      box.appendChild(row);
    });
  }

  function colorOf(n){ if (n===0) return 'green'; return REDS.has(n)?'red':'black'; }

  // Drawing + animation
  const cv = document.getElementById('wheelCanvas');
  const ctx = cv.getContext('2d');
  const R = cv.width/2;
  const cx = R, cy = R;
  let wheelAngle = -Math.PI/2; // 0 at top
  let ballAngle = wheelAngle + Math.PI; // opposite side to start
  let spinning = false;
  let animId = null;
  let targetAngle = 0;
  let spinStart = 0;
  let spinDur = 2600; // ms
  let resultIndex = 0;

  function drawWheel(){
    ctx.clearRect(0,0,cv.width,cv.height);

    // Outer rim
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(wheelAngle);

    const seg = (Math.PI*2)/ORDER.length;

    // Segments
    for (let i=0;i<ORDER.length;i++){
      const n = ORDER[i];
      const col = colorOf(n);
      ctx.beginPath();
      ctx.moveTo(0,0);
      ctx.arc(0,0,R-6,i*seg,(i+1)*seg);
      ctx.closePath();
      // pick UI colors
      let fill;
      const styles = getComputedStyle(document.body);
      const ph = styles.getPropertyValue('--ph') || '#98ff9f';
      const dim = styles.getPropertyValue('--dim') || 'rgba(152,255,159,.45)';

      if (col==='red') fill = 'rgba(255,0,0,0.22)';
      else if (col==='black') fill = 'rgba(0,0,0,0.6)';
      else fill = 'rgba(0,0,0,0.6)'; // was green; removed highlight
      ctx.fillStyle = fill;
      ctx.fill();
      ctx.strokeStyle = dim; ctx.lineWidth = 1; ctx.stroke();

      // Number ring
      const mid = (i+0.5)*seg;
      ctx.save();
      ctx.rotate(mid);
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = ph;
      ctx.font = '12px ui-monospace, Menlo, monospace';
      ctx.translate(0, -(R-28));
      ctx.rotate(Math.PI/2);
      ctx.fillText(String(n), 0, 0);
      ctx.restore();
    }

    // Inner ring
    ctx.beginPath();
    ctx.arc(0,0,R-40,0,Math.PI*2);
    ctx.strokeStyle = getComputedStyle(document.body).getPropertyValue('--dim') || '#555';
    ctx.lineWidth = 2;
    ctx.stroke();

    ctx.restore();

    // Pointer at top
    ctx.beginPath();
    ctx.moveTo(cx, cy-(R-2));
    ctx.lineTo(cx-10, cy-(R-20));
    ctx.lineTo(cx+10, cy-(R-20));
    ctx.closePath();
    ctx.fillStyle = getComputedStyle(document.body).getPropertyValue('--ph') || '#98ff9f';
    ctx.fill();

    // Ball
    const ballR = R-24;
    const bx = cx + Math.cos(ballAngle)*ballR;
    const by = cy + Math.sin(ballAngle)*ballR;
    ctx.beginPath();
    ctx.arc(bx, by, 4, 0, Math.PI*2);
    ctx.fillStyle = '#fff';
    ctx.fill();
  }

  function angleForIndex(idx){
    // segment i is centered at angle i*seg + seg/2 relative to wheel; pointer is at -PI/2
    const seg = (Math.PI*2)/ORDER.length;
    const center = idx*seg + seg/2;
    return -Math.PI/2 - center; // wheel angle such that index center hits pointer
  }

  function easeOutCubic(t){ return 1 - Math.pow(1-t,3); }

  function animate(){
    const now = performance.now();
    const t = Math.min(1, (now - spinStart)/spinDur);
    const e = easeOutCubic(t);

    // Wheel goes from current to targetAngle with easing
    const a = wheelAngle + (targetAngle - wheelAngle) * e;

    // Ball runs faster initially and decouples slightly
    const extra = (1-t) * 6.0; // extra laps early
    ballAngle = a - (Math.PI*2)*extra;

    wheelAngle = a;
    drawWheel();

    if (t < 1){
      animId = requestAnimationFrame(animate);
    } else {
      spinning = false;
      cancelAnimationFrame(animId);
      animId = null;
      // Determine result
      const seg = (Math.PI*2)/ORDER.length;
      // compute final index from wheelAngle
      // invert angleForIndex: nearest index whose angleForIndex equals wheelAngle modulo 2π
      let raw = (-wheelAngle - Math.PI/2);
      raw = (raw % (Math.PI*2) + Math.PI*2) % (Math.PI*2);
      const idx = Math.floor((raw)/seg);
      const result = ORDER[idx];
      finalizeSpin(result);
    }
  }

  function startSpinToIndex(idx){
    // pick a few extra revs for flair
    const extraTurns = 3 + Math.floor(Math.random()*3);
    const dest = angleForIndex(idx) - (Math.PI*2)*extraTurns;
    targetAngle = dest;
    spinStart = performance.now();
    spinDur = 2400 + Math.random()*900;
    spinning = true;
    if (animId) cancelAnimationFrame(animId);
    animId = requestAnimationFrame(animate);
  }

  function payoutFor(result){
    let payout = 0;
    for (const b of bets){
      if (b.type==='straight'){
        if (result===b.pick) payout += b.amount * 36;
      } else if (b.type==='red' || b.type==='black'){
        const col = colorOf(result);
        if ((b.type==='red' && col==='red') || (b.type==='black' && col==='black')) payout += b.amount*2;
      } else if (b.type==='odd' || b.type==='even'){
        if (result!==0 && ((b.type==='odd' && result%2===1) || (b.type==='even' && result%2===0))) payout += b.amount*2;
      } else if (b.type==='dozen1'){
        if (result>=1 && result<=12) payout += b.amount*3;
      } else if (b.type==='dozen2'){
        if (result>=13 && result<=24) payout += b.amount*3;
      } else if (b.type==='dozen3'){
        if (result>=25 && result<=36) payout += b.amount*3;
      }
    }
    return payout;
  }

  function finalizeSpin(result){
    const col = colorOf(result);
    const net = payoutFor(result);
    adjustBalance(net);
    try { ws && ws.send && ws.send(JSON.stringify({type:'casino', game:'roulette', action:'resolve', result, payout:net})); } catch(e){}
    document.getElementById('lastResult').textContent = `Last: ${result} (${col}) — ${net? 'Won '+fmtLocal(net):'No win'}`;
    bets.length = 0;
    renderBets(); refreshRouletteBalance();
  }

  // Controls
  const betAmount = document.getElementById('betAmount');
  const betType = document.getElementById('betType');
  const straightNum = document.getElementById('straightNum');
  document.getElementById('placeBet').onclick = ()=>{
    if (spinning) return;
    const amt = Math.max(1, Number(betAmount.value||0));
    if (amt > getBalance()) { alert('Insufficient funds.'); return; }
    const type = betType.value;
    let label = type;
    let pick = null;
    if (type==='straight'){
      const n = Math.max(0, Math.min(36, Number(straightNum.value||0)));
      pick = n; label = `Straight ${n}`;
    } else {
      pick = type;
      label = type.charAt(0).toUpperCase()+type.slice(1);
    }
    bets.push({type, pick, amount: amt, label});
    adjustBalance(-amt); // escrow
    try { ws && ws.send && ws.send(JSON.stringify({type:'casino', game:'roulette', action:'bet', amount:amt, pick, kind:type})); } catch(e){}
    renderBets(); refreshRouletteBalance();
  };

  document.getElementById('spinBtn').onclick = ()=>{
    if (spinning) return;
    if (!bets.length) { alert('Place a bet first.'); return; }
    document.getElementById('lastResult').textContent = 'Spinning…'; // Pick fair random outcome
    resultIndex = Math.floor(Math.random()*ORDER.length);
    startSpinToIndex(resultIndex);
  };

  // Sync with portfolio updates
  const _origRenderPositions = (typeof renderPositions==='function') ? renderPositions : null;
  if (_origRenderPositions){
    window.renderPositions = function(p){
      _origRenderPositions(p);
      refreshRouletteBalance();
    };
  }

  // Initial draw
  drawWheel();
  refreshRouletteBalance();
})();
  // Time control selector behavior
  (function(){
    const tcSel = document.getElementById('chessTimeControl');
    if (!tcSel) return;
    tcSel.addEventListener('change', ()=>{
      setTimeControlFromSelect();
      if (!playing){ resetClockUI(); }
      else { status('Time control will apply next game.'); }
    });
  })();

</script>

<script>
// === BLACKJACK (isolated, no edits to existing code) ===
(function(){
