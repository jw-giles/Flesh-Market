    const elo = Number(document.getElementById('chessElo').value);
    const fee = feeForElo(elo);
    if (getBalance() < fee){ status('Insufficient funds for entry fee.'); return; }
    adjustBalance(-fee);
    refreshChessBalance();
    game = { board: startPosition(), turn:'w' };
    selected=null; moves=[]; playing=true;
    drawBoard(game.board);
    turnLabel('w');
    status('Game started. You are White.');
  }

  
  
  
  document.getElementById('chessSurrender').addEventListener('click', ()=>{
    if (!playing) { status('No game in progress.'); return; }
    endGame('loss');
  });

  document.getElementById('chessElo').addEventListener('change', updateMoneyText);
  const startBtn = document.getElementById('chessStart'); if (startBtn) startBtn.addEventListener('click', startGame);
  



  if (toggleBtn){
    toggleBtn.addEventListener('click', ()=>{
      if (!playing){
        startGame();
        toggleBtn.textContent = 'Surrender';
      } else {
        endGame('surrender');
        toggleBtn.textContent = 'Start';
      }
    });
  }

  updateMoneyText();
  refreshChessBalance();
  // render initial
  game = { board: startPosition(), turn:'w' };
  drawBoard(game.board);
  status('Choose difficulty and press Start.');
  turnLabel('w');
})();
</script>


<script type="module">
import { createNPCEngine } from "./npc/npc_traders.js";

(async () => {
  try {
    const npc = await createNPCEngine({}).init();
    // Try to detect a global tick bus (non-breaking no-op if absent)
    const tryHook = () => {
      const w = window;
      // If there's a global market object with subscribe/onTick API
      const bus = w.market?.onTick || w.market?.subscribe || w.onMarketTick;
      if (typeof bus === "function") {
        bus((symbol, state) => {
          try {
            if (!state || typeof state.price !== "number") return;
            state.timeMs = Date.now();
            state.symbol = symbol;
            state.seedRand = state.seedRand || Math.random;
            const res = npc.apply(symbol, state);
            if (res && res.dPrice) {
              // apply drift directly to the mutable state; most engines read-back this object
              state.price += res.dPrice;
            }
          } catch (e) { /* swallow */ }
        });
        console.log("[NPC] hooked into market tick bus");
        return true;
      }
      return false;
    };
    if (!tryHook()) {
      // Fallback: if there's a global priceUpdate(symbol, price) function, wrap it
      const w = window;
      if (typeof w.priceUpdate === "function") {
        const orig = w.priceUpdate;
        w.priceUpdate = function(symbol, price, ...rest){
          const state = { price, last: price, sma: price, ema: price, rsi: 50, vol24h: 0, symbol, timeMs: Date.now(), seedRand: Math.random };
          const res = npc.apply(symbol, state);
          const newPrice = price + (res?.dPrice || 0);
          return orig.call(this, symbol, newPrice, ...rest);
        };
        console.log("[NPC] wrapped priceUpdate()");
      } else {
        console.log("[NPC] no hook target found; NPC engine idle (safe no-op).");
      }
    }
  } catch (e) { console.warn("[NPC] init failed", e); }
})();
</script>

