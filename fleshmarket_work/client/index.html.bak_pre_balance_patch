  }

  // UI
  pane.innerHTML = `<div class="row" style="gap:12px; flex-wrap:wrap">
      <div class="crt" style="flex:1; min-width:260px; padding:12px; border:1px solid var(--dim)">
        <div class="muted" id="shoeInfo">Shoe: —</div>
