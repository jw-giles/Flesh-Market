    clock.turn = turn;
    if (clock.interval) clearInterval(clock.interval);
    clock.running = true;
    const tick = ()=>{
      if (!clock.running) return;
      if (clock.turn==='w') { clock.w -= 0.1; if (clock.w<=0){ clock.w=0; updateClockDisplay(); endGame('time_white'); return; } }
      else { clock.b -= 0.1; if (clock.b<=0){ clock.b=0; updateClockDisplay(); endGame('time_black'); return; } }
      updateClockDisplay();
    };
    clock.interval = setInterval(tick, 100);
  }

  function stopClock(){
