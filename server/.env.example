PORT=7777
TRADE_TAX_BPS=25

# Patreon webhook secret — get this from your Patreon webhook dashboard
# Leave blank during dev (skips signature verification)
PATREON_WEBHOOK_SECRET=

# Optional: custom DB path
# DB_PATH=./fleshmarket.db

# Comma-separated dev account names — MrFlesh MUST be first (prime/owner account)
# Run node seed_devaccounts.mjs after adding names to create hashed credentials
DEV_ACCOUNTS=MrFlesh,DEV-FIXER,DEV-SLUT,DEV-SMASHER,DEV-GURU,DEV-PEAK
